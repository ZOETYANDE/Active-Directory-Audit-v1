# Active Directory Audit Configuration v2.0
# Usage: ./activeD_Audit.sh --config audit.conf -u <username>

# ═══════════════════════════════════════════════════════
# TARGET
# ═══════════════════════════════════════════════════════
DC_IP=[IP_ADDRESS]
DC_HOSTNAME=                # DC hostname (e.g. DC01) — leave empty for auto-detect
DOMAIN=[YOUR DOMAIN]
NETWORK=[IP_ADDRESS]      # Leave empty for auto-detect from DC_IP

# ═══════════════════════════════════════════════════════
# OPTIONS
# ═══════════════════════════════════════════════════════
LDAPS=false                 # Use LDAPS (port 636) instead of LDAP (389)
INACTIVITY_DAYS=90          # Days before a user is considered inactive
ENCRYPT_OUTPUT=false        # GPG-encrypt the final archive

# ═══════════════════════════════════════════════════════
# MODULES (v2.0)
# ═══════════════════════════════════════════════════════
# SELECTED_MODULES=         # Comma-separated list of modules to run (empty = all)
# SKIP_MODULES=             # Comma-separated list of modules to skip
#
# Available modules:
#   Unauthenticated: inventory, dc_config, ldap_unauth, smb_unauth, dns
#   Authenticated:   users, groups, inactive, computers, password, gpo,
#                    shares, delegation, acl, trusts, laps, adcs,
#                    vulns, misc, bloodhound
#
# Examples:
#   SELECTED_MODULES=users,groups,password,bloodhound
#   SKIP_MODULES=bloodhound,adcs
